{
  "name": "robium-website",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n site,orch -c cyan,magenta \"astro dev\" \"npm --prefix demo-orchestrator run dev\"",
    "dev:site": "astro dev",
    "dev:orch": "npm --prefix demo-orchestrator run dev",
    "build": "node scripts/fetch-skills.mjs && astro build",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@fontsource-variable/inter": "^5.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "astro": "^6.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.12.2"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
