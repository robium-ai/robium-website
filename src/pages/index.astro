import PluginAnatomy from '../components/PluginAnatomy.astro';
import SkillsTable from '../components/SkillsTable.astro';
import Apps from '../components/Apps.astro';
import Faq from '../components/Faq.astro';
import Footer from '../components/Footer.astro';
---
<Base bodyClass="landing">
  <Nav />
  <main>
    <Hero />
    <CatalogBelt />
    <PluginAnatomy />
    <SkillsTable />
    <Apps />
    <Faq />
  </main>
  <Footer />
</Base>
