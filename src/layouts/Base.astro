---
import '../styles/theme.css';
const { title = 'robium — Physical AI expertise for AI agents' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="robium gives AI agents the expertise to architect, build, and validate Physical AI applications across simulation, data, visualization, and robotics integration."
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
