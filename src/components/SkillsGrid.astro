---
import { existsSync } from 'node:fs';
import AgentTabs from './AgentTabs.astro';
import skills from '../data/skills.json';
import pillars from '../data/pillars.json';

const REPO = 'https://github.com/jazarium/robium-docs/tree/main/skills';

// Best-effort brand marks. A skill with no entry (or no SVG on disk) gets the
// neutral glyph. Only these five SVGs exist today; see docs/BACKLOG.md.
const LOGOS = {
  ros2: 'ros.svg',
  nav2: 'ros.svg',
  'isaac-sim': 'nvidia.svg',
  'isaac-lab': 'nvidia.svg',
  huggingface: 'huggingface.svg',
  lerobot: 'huggingface.svg',
};

const byName = new Map(skills.map((s) => [s.name, s]));

// Validate that all skill names in pillars.json exist in skills.json.
// pillars.json is hand-maintained; skills.json is generated. A mismatch is
// always a bug (skill renamed or removed upstream). Fail the build loudly.
const missingSkills = new Set<string>();
for (const pillar of pillars) {
  for (const skillName of pillar.skills) {
    if (!byName.has(skillName)) {
      missingSkills.add(skillName);
    }
  }
}
if (missingSkills.size > 0) {
  throw new Error(
    `Skill mismatch: ${Array.from(missingSkills).join(', ')} named in src/data/pillars.json ` +
    `but missing from src/data/skills.json (generated from robium repo). ` +
    `Check if the skill was renamed or removed upstream.`
  );
}

const groups = pillars.map((p) => ({
  ...p,
  cards: p.skills
    .map((name) => byName.get(name))
    .filter(Boolean)
    .map((s) => {
      const file = LOGOS[s.name];
      return { ...s, logo: file && existsSync(`public/logos/${file}`) ? file : null };
    }),
}));
---
<section id="skills">
  <div class="container">
    <div class="sec-head">
      <span class="label">Browse skills catalog</span>
      <h2>One stop shop for every robotics skill your AI agent is missing.</h2>
      <p class="lead">
        AI agents are good at code. Robotics asks for more than code — a sprawling
        stack, scattered docs, and the hard-won judgment that usually lives only in
        an engineer's head. Robium hands your agent that judgment: hand-crafted,
        well-tested skills, and an architect that turns a plain-language ask into a
        real stack decision. Install it into the coding agent you already use.
      </p>
    </div>

    <AgentTabs />

    <div class="catalog">
    {groups.map((g) => (
      <div class="pillar">
        <div class="pillar-head">
          <h3 class="pillar-title">{g.title}</h3>
          <p class="pillar-blurb">{g.blurb}</p>
        </div>
        <div class="grid">
          {g.cards.map((s) => (
            <a class="card skill" href={`${REPO}/${s.name}`}>
              <div class="head">
                {s.logo
                  ? <img src={`/logos/${s.logo}`} alt="" width="18" height="18" loading="lazy" />
                  : <span class="glyph" aria-hidden="true"></span>}
                <span class="name">{s.name}</span>
                <span class="ver">v{s.version}</span>
              </div>
              <p>{s.description}</p>
            </a>
          ))}
        </div>
      </div>
    ))}
    </div>
  </div>
</section>

<style>
  .sec-head { text-align: center; margin-bottom: 44px; }
  h2 { margin: 14px auto 20px; text-wrap: balance; max-width: 18em; }
  .lead { color: var(--text2); margin: 0 auto; max-width: 46em; text-wrap: pretty; }
  .catalog { margin-top: 80px; }

  .pillar { margin-bottom: 48px; }
  .pillar-head { margin-bottom: 16px; }
  .pillar-title { font-size: 18px; margin: 0 0 4px; }
  .pillar-blurb { font-size: 14px; color: var(--muted); margin: 0; }

  .grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }

  .skill { display: block; text-decoration: none; transition: border-color 150ms; }
  .skill:hover { border-color: var(--accent); }
  .skill .head { display: flex; align-items: baseline; gap: 8px; margin-bottom: 8px; }
  .skill .head img { align-self: center; }
  .glyph {
    width: 18px; height: 18px; border-radius: 5px; align-self: center;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    opacity: 0.55;
  }
  .name {
    font-family: ui-monospace, Menlo, monospace; font-weight: 600;
    font-size: 15px; color: var(--text);
  }
  .ver { margin-left: auto; font-size: 12px; color: var(--muted); font-family: ui-monospace, Menlo, monospace; }
  .skill p { font-size: 13.5px; color: var(--text2); line-height: 1.55; margin: 0; }

  @media (max-width: 1000px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .grid { grid-template-columns: 1fr; } }
</style>
