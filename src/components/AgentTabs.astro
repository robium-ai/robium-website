---
// CSS-only tabs: the radios precede everything so `:checked ~` can reach the
// labels and panels. No client-side JS — the landing page ships none by contract.
---
<div class="tabs card">
  <input type="radio" name="agent" id="agent-claude" class="tab-radio" checked />
  <input type="radio" name="agent" id="agent-cursor" class="tab-radio" />
  <input type="radio" name="agent" id="agent-gemini" class="tab-radio" />

  <div class="tab-bar">
    <label for="agent-claude">Claude Code</label>
    <label for="agent-cursor">Cursor <span class="soon">soon</span></label>
    <label for="agent-gemini">Gemini <span class="soon">soon</span></label>
  </div>

  <pre class="panel" data-tab="claude"><span class="tp">npx robium-ai install</span>
<span class="tp">claude</span>

<span class="ta">&gt; build a mobile robot that navigates in sim</span></pre>

  <pre class="panel" data-tab="cursor">Native Cursor packaging is next.
robium's skills are plain Markdown — the
manifest is the only missing piece.

<span class="ta">&gt; build a mobile robot that navigates in sim</span></pre>

  <pre class="panel" data-tab="gemini">Native Gemini packaging is next.
robium's skills are plain Markdown — the
manifest is the only missing piece.

<span class="ta">&gt; build a mobile robot that navigates in sim</span></pre>
</div>

<style>
  .tabs { padding: 0; overflow: hidden; }
  .tab-radio { position: absolute; opacity: 0; pointer-events: none; }

  .tab-bar {
    display: flex; gap: 4px;
    padding: 8px 8px 0;
    border-bottom: 1px solid var(--border);
    background: var(--bg2);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .tab-bar label {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 14px; border-radius: 8px 8px 0 0;
    font-size: 13px; color: var(--muted); cursor: pointer;
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    border: 1px solid transparent; border-bottom: none;
    transition: color 150ms, background 150ms;
    white-space: nowrap; flex: 0 0 auto;
  }
  .tab-bar label:hover { color: var(--text2); }
  @media (max-width: 400px) {
    .tab-bar label { padding: 10px 10px; font-size: 12.5px; }
  }
  .soon {
    font-size: 10px; text-transform: uppercase; letter-spacing: 0.04em;
    padding: 2px 6px; border-radius: 999px;
    background: var(--border); color: var(--muted);
  }

  .panel {
    display: none;
    padding: 20px 24px; margin: 0; overflow-x: auto;
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 13.5px; line-height: 1.7; color: var(--text2);
  }
  .panel .tp { color: var(--text); }
  .panel .ta { color: var(--accent2); }

  /* selected tab gets the card background + full-contrast text */
  #agent-claude:checked ~ .tab-bar label[for="agent-claude"],
  #agent-cursor:checked ~ .tab-bar label[for="agent-cursor"],
  #agent-gemini:checked ~ .tab-bar label[for="agent-gemini"] {
    color: var(--text); background: var(--card); border-color: var(--border);
  }

  /* only the selected panel renders */
  #agent-claude:checked ~ .panel[data-tab="claude"],
  #agent-cursor:checked ~ .panel[data-tab="cursor"],
  #agent-gemini:checked ~ .panel[data-tab="gemini"] { display: block; }

  /* keyboard access: the label is focusable via its radio */
  .tab-radio:focus-visible ~ .tab-bar label[for] { outline: none; }
  #agent-claude:focus-visible ~ .tab-bar label[for="agent-claude"],
  #agent-cursor:focus-visible ~ .tab-bar label[for="agent-cursor"],
  #agent-gemini:focus-visible ~ .tab-bar label[for="agent-gemini"] {
    outline: 2px solid var(--accent2); outline-offset: -2px;
  }
</style>
