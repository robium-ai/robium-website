<style>
  .nav {
    position: sticky; top: 0; z-index: 10;
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 3px solid var(--accent);
  }
  .nav-inner { display: flex; align-items: center; gap: 28px; height: 58px; }
  .brand {
    font-family: var(--mono); font-weight: 700; font-size: 17px;
    letter-spacing: -0.02em; color: var(--ink); text-decoration: none;
  }
  .brand em { font-style: normal; color: var(--accent-ink); }
  .links { display: flex; align-items: center; gap: 22px; margin-left: auto; }
  .links a { color: var(--ink2); text-decoration: none; font-size: 14px; transition: color 150ms; }
  .links a:hover { color: var(--ink); }
  .gh { display: flex; }

  #theme-toggle {
    display: flex; align-items: center; justify-content: center;
    width: 32px; height: 32px; padding: 0;
    border: 1px solid var(--border2); border-radius: 8px;
    background: var(--bg); color: var(--ink2); cursor: pointer;
    transition: color 150ms, border-color 150ms;
  }
  #theme-toggle:hover { color: var(--ink); border-color: var(--ink); }
  /* moon in light mode (click → dark), sun in dark mode (click → light) */
  #theme-toggle .icon-sun { display: none; }
  :global(html[data-theme='dark']) #theme-toggle .icon-sun { display: block; }
  :global(html[data-theme='dark']) #theme-toggle .icon-moon { display: none; }

  @media (max-width: 640px) { .links a:not(.gh) { display: none; } }
</style>

<script>
  // Theme switch: flip html[data-theme], persist the choice. The pre-paint
  // script in Base.astro applies it on the next load.
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
    root.dataset.theme = next;
    try { localStorage.setItem('theme', next); } catch {}
  });
</script>
